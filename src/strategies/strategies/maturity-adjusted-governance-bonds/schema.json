{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/Strategy",
  "definitions": {
    "Strategy": {
      "title": "Rize Governance Bonds",
      "type": "object",
      "properties": {
        "nftBondAddress": {
          "type": "string",
          "title": "NFTBond address",
          "pattern": "^0x[a-fA-F0-9]{40}$",
          "minLength": 42,
          "maxLength": 42
        },
        "governanceBondingAddress": {
          "type": "string",
          "title": "GovernanceBonding address",
          "pattern": "^0x[a-fA-F0-9]{40}$",
          "minLength": 42,
          "maxLength": 42
        },
        "decimals": {
          "type": "number",
          "title": "Decimals",
          "examples": [2]
        },
        "maxBondsPerAddress": {
          "type": "number",
          "title": "Max bonds per address",
          "examples": [10]
        },
        "symbol": {
          "type": "string",
          "title": "Symbol",
          "examples": ["gRIZE"],
          "maxLength": 16
        }
      },
      "required": ["nftBondAddress", "governanceBondingAddress"],
      "additionalProperties": false
    }
  }
}
